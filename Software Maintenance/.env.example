# Software Maintenance Exam Prep — environment template.
# Copy to `.env` for local overrides (the .env file is gitignored, never committed).
# This is a local, single-user, offline app: there are NO secrets, API keys, or
# credentials here — only filesystem paths and the HTTP port.
#
#   cp .env.example .env
#
# Note: under Docker/Podman the in-container paths are set by the image/compose
# file (PDF_ROOT=/data/pdfs, etc.). These values matter mainly when running the
# app or ingest directly on the host (outside a container).

# Root that holds the source slide PDFs (the `Lecture N/` folders live here).
# Mounted read-only; used by ingest discovery and the /slide render endpoint.
PDF_ROOT=./

# Directory of generated per-lecture study-guide markdown (the embedded corpus).
GUIDE_ROOT=./data/guides

# Directory of per-lecture MCQ JSON files (the quiz bank, loaded into memory).
MCQ_ROOT=./data/mcqs

# Persisted ChromaDB vector store (created by `ingest`, read by the app).
CHROMA_DIR=./data/chroma_db

# Port the FastAPI app listens on.
PORT=8000
