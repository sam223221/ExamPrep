<mxfile host="app.diagrams.net" modified="2026-06-12T00:00:00.000Z" agent="exam-prep" version="24.0.0" type="device"><diagram id="d1" name="GitFourAreas"><mxGraphModel dx="800" dy="600" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1169" pageHeight="826" math="0" shadow="0"><root><mxCell id="0"/><mxCell id="1" parent="0"/><mxCell id="c1" value="1. Workspace&#10;(working dir — your editable files)" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;verticalAlign=top;fontStyle=1;fontSize=12;" vertex="1" parent="1"><mxGeometry x="60" y="60" width="160" height="660" as="geometry"/></mxCell><mxCell id="c2" value="2. Index / stage&#10;(what the next commit will contain)" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;verticalAlign=top;fontStyle=1;fontSize=12;" vertex="1" parent="1"><mxGeometry x="320" y="60" width="160" height="660" as="geometry"/></mxCell><mxCell id="c3" value="3. Local Repository&#10;(committed history, HEAD)" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;verticalAlign=top;fontStyle=1;fontSize=12;" vertex="1" parent="1"><mxGeometry x="580" y="60" width="160" height="660" as="geometry"/></mxCell><mxCell id="c4" value="4. Remote Repository&#10;(origin — the shared fork on GitHub)" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;verticalAlign=top;fontStyle=1;fontSize=12;" vertex="1" parent="1"><mxGeometry x="840" y="60" width="160" height="660" as="geometry"/></mxCell><mxCell id="note" value="Four-area workflow (Git Lab p.11): add stages, commit records locally, push publishes; pull = fetch + merge. Commit is local — teammates see nothing until you push." style="text;html=1;align=left;verticalAlign=middle;whiteSpace=wrap;fontSize=11;fontColor=#666666;" vertex="1" parent="1"><mxGeometry x="60" y="750" width="740" height="40" as="geometry"/></mxCell><mxCell id="eClone" value="clone — full local copy of everything; remote linked as origin" style="edgeStyle=none;rounded=0;html=1;exitX=0;exitY=0.15;exitDx=0;exitDy=0;entryX=1;entryY=0.15;entryDx=0;entryDy=0;fontSize=11;labelBackgroundColor=#ffffff;" edge="1" parent="1" source="c4" target="c1"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="eAdd" value="add (-u) — stage changes" style="edgeStyle=none;rounded=0;html=1;exitX=1;exitY=0.24;exitDx=0;exitDy=0;entryX=0;entryY=0.24;entryDx=0;entryDy=0;fontSize=11;labelBackgroundColor=#ffffff;" edge="1" parent="1" source="c1" target="c2"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="eCommit" value="commit — record to HEAD" style="edgeStyle=none;rounded=0;html=1;exitX=1;exitY=0.33;exitDx=0;exitDy=0;entryX=0;entryY=0.33;entryDx=0;entryDy=0;fontSize=11;labelBackgroundColor=#ffffff;" edge="1" parent="1" source="c2" target="c3"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="ePush" value="push — publish commits" style="edgeStyle=none;rounded=0;html=1;exitX=1;exitY=0.42;exitDx=0;exitDy=0;entryX=0;entryY=0.42;entryDx=0;entryDy=0;fontSize=11;labelBackgroundColor=#ffffff;" edge="1" parent="1" source="c3" target="c4"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="eFetch" value="fetch — download commits; workspace untouched" style="edgeStyle=none;rounded=0;html=1;exitX=0;exitY=0.52;exitDx=0;exitDy=0;entryX=1;entryY=0.52;entryDx=0;entryDy=0;fontSize=11;labelBackgroundColor=#ffffff;" edge="1" parent="1" source="c4" target="c3"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="eMerge" value="merge — integrate into workspace" style="edgeStyle=none;rounded=0;html=1;exitX=0;exitY=0.61;exitDx=0;exitDy=0;entryX=1;entryY=0.61;entryDx=0;entryDy=0;fontSize=11;labelBackgroundColor=#ffffff;" edge="1" parent="1" source="c3" target="c1"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="ePull" value="pull = fetch + merge (one step)" style="edgeStyle=none;rounded=0;html=1;exitX=0;exitY=0.7;exitDx=0;exitDy=0;entryX=1;entryY=0.7;entryDx=0;entryDy=0;fontSize=11;labelBackgroundColor=#ffffff;" edge="1" parent="1" source="c4" target="c1"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="eCheckout" value="checkout / restore — files from history" style="edgeStyle=none;rounded=0;html=1;exitX=0;exitY=0.79;exitDx=0;exitDy=0;entryX=1;entryY=0.79;entryDx=0;entryDy=0;fontSize=11;labelBackgroundColor=#ffffff;" edge="1" parent="1" source="c3" target="c1"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="eDiff" value="diff — workspace vs index (unstaged edits)" style="edgeStyle=none;rounded=0;html=1;dashed=1;startArrow=none;endArrow=none;exitX=1;exitY=0.88;exitDx=0;exitDy=0;entryX=0;entryY=0.88;entryDx=0;entryDy=0;fontSize=11;labelBackgroundColor=#ffffff;" edge="1" parent="1" source="c1" target="c2"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="eDiffHead" value="diff HEAD — workspace vs last commit (staged + unstaged)" style="edgeStyle=none;rounded=0;html=1;dashed=1;startArrow=none;endArrow=none;exitX=1;exitY=0.95;exitDx=0;exitDy=0;entryX=0;entryY=0.95;entryDx=0;entryDy=0;fontSize=11;labelBackgroundColor=#ffffff;" edge="1" parent="1" source="c1" target="c3"><mxGeometry relative="1" as="geometry"/></mxCell></root></mxGraphModel></diagram></mxfile>
