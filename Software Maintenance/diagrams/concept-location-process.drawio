<mxfile host="app.diagrams.net" modified="2026-06-12T00:00:00.000Z" agent="exam-prep" version="24.0.0" type="device"><diagram id="d1" name="ConceptLocationProcess"><mxGraphModel dx="800" dy="600" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1169" pageHeight="826" math="0" shadow="0"><root><mxCell id="0"/><mxCell id="1" parent="0"/><mxCell id="start" value="Change request:&#10;concept to locate&#10;(watermark example: Export, Drawing, Text, Format — ConceptLocation p.6)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=12;" vertex="1" parent="1"><mxGeometry x="40" y="330" width="200" height="100" as="geometry"/></mxCell><mxCell id="lblStatic" value="STATIC SEARCH — code does not run" style="text;html=1;align=left;verticalAlign=middle;whiteSpace=wrap;fontSize=12;fontStyle=1;" vertex="1" parent="1"><mxGeometry x="290" y="110" width="320" height="30" as="geometry"/></mxCell><mxCell id="grep" value="Pattern matching: GREP&#10;query → investigate → refine" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=12;" vertex="1" parent="1"><mxGeometry x="280" y="170" width="190" height="80" as="geometry"/></mxCell><mxCell id="readcode" value="Read candidate code&#10;(partial comprehension)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=12;" vertex="1" parent="1"><mxGeometry x="510" y="170" width="190" height="80" as="geometry"/></mxCell><mxCell id="depsearch" value="Dependency search —&#10;follow the class dependency graph" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=12;" vertex="1" parent="1"><mxGeometry x="740" y="170" width="190" height="80" as="geometry"/></mxCell><mxCell id="lblDyn" value="DYNAMIC SEARCH — execution traces (program runs)" style="text;html=1;align=left;verticalAlign=middle;whiteSpace=wrap;fontSize=12;fontStyle=1;" vertex="1" parent="1">