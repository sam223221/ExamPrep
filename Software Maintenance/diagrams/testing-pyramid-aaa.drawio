<mxCell id="cap" value="Each level catches a different class of fault — use all three (Software Testing p.8)" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;fontSize=11;fontStyle=2;" vertex="1" parent="1"><mxGeometry x="70" y="520" width="460" height="30" as="geometry"/></mxCell>
<mxCell id="a1" value="Arrange&#10;set up the fixture and assert the precondition&#10;e.g. assertFalse(libApp.adminLoggedIn())" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;" vertex="1" parent="1"><mxGeometry x="700" y="150" width="380" height="90" as="geometry"/></mxCell>
<mxCell id="a2" value="Act&#10;perform the action under test&#10;e.g. boolean login = libApp.adminLogin(&quot;adminadmin&quot;)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;" vertex="1" parent="1"><mxGeometry x="700" y="290" width="380" height="90" as="geometry"/></mxCell>
<mxCell id="a3" value="Assert&#10;assert the postcondition&#10;e.g. assertTrue(login); assertTrue(libApp.adminLoggedIn())" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;" vertex="1" parent="1"><mxGeometry x="700" y="430" width="380" height="90" as="geometry"/></mxCell>
