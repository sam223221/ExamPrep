<mxCell id="p1" value="System / GUI tests&#10;(few, slow — whole system end-to-end&#10;against its specification)" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;" vertex="1" parent="1"><mxGeometry x="190" y="150" width="220" height="80" as="geometry"/></mxCell>
<mxCell id="p2" value="Integration tests&#10;(already-unit-tested components working&#10;together across their interfaces)" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;" vertex="1" parent="1"><mxGeometry x="130" y="270" width="340" height="80" as="geometry"/></mxCell>
