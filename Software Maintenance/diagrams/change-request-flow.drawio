<mxfile host="app.diagrams.net" modified="2026-06-12T00:00:00.000Z" agent="exam-prep" version="24.0.0" type="device"><diagram id="d1" name="ChangeRequestFlow"><mxGraphModel dx="800" dy="600" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1169" pageHeight="826" math="0" shadow="0"><root><mxCell id="0"/><mxCell id="1" parent="0"/><mxCell id="story" value="User Story (3x5 card):&#10;&quot;As a [user type], I want [some goal]&#10;so that [some reason]&quot;&#10;(ChangeInitiation p.4–5)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=12;" vertex="1" parent="1"><mxGeometry x="40" y="40" width="300" height="80" as="geometry"/></mxCell><mxCell id="issue" value="GitHub Issue #N&#10;(feature, bug fix, or improvement)&#10;(Git Lab p.19)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=12;" vertex="1" parent="1"><mxGeometry x="420" y="50" width="280" height="70" as="geometry"/></mxCell><mxCell id="laneTodo" value="TODO — product backlog (prioritized wish list)" style="swimlane;html=1;startSize=30;fontStyle=1;fontSize=12;fillColor=#f5f5f5;strokeColor=#666666;swimlaneFillColor=#ffffff;" vertex="1" parent="1"><mxGeometry x="40" y="180" width="330" height="540" as="geometry"/></mxCell><mxCell id="cardTodo" value="Story card: &quot;As a [user type], I want [goal] so that [reason]&quot;&#10;linked to Issue #N&#10;priority: Must / Nice-to-have / Won't have" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=12;" vertex="1" parent="laneTodo"><mxGeometry x="25" y="60" width="280" height="100" as="geometry"/></mxCell><mxCell id="laneProg" value="In Progress" style="swimlane;html=1;startSize=30;fontStyle=1;fontSize=12;fillColor=#f5f5f5;strokeColor=#666666;swimlaneFillColor=#ffffff;" vertex="1" parent="1"><mxGeometry x="410" y="180" width="330" height="540" as="geometry"/></mxCell><mxCell id="cardBranch" value="git checkout -b feature/&lt;short-name&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=12;" vertex="1" parent="laneProg"><mxGeometry x="25" y="60" width="280" height="60" as="geometry"/></mxCell><mxCell id="cardCommits" value="small commits referencing #N&#10;(messages explain WHY)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=12;" vertex="1" parent="laneProg"><mxGeometry x="25" y="160" width="280" height="70" as="geometry"/></mxCell><mxCell id="cardPR" value="push branch; open Pull Request;&#10;CI builds the PR" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=12;" vertex="1" parent="laneProg"><mxGeometry x="25" y="270" width="280" height="70" as="geometry"/></mxCell><mxCell id="laneDone" value="Done" style="swimlane;html=1;startSize=30;fontStyle=1;fontSize=12;fillColor=#f5f5f5;strokeColor=#666666;swimlaneFillColor=#ffffff;" vertex="1" parent="1"><mxGeometry x="780" y="180" width="330" height="540" as="geometry"/></mxCell><mxCell id="cardDone" value="PR reviewed and merged into main&#10;— card moves to Done" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=12;" vertex="1" parent="laneDone"><mxGeometry x="25" y="60" width="280" height="90" as="geometry"/></mxCell><mxCell id="note" value="Traceable chain: request → backlog → branch → commits → merge (ChangeReqLab p.1; Git Lab p.19)" style="text;html=1;align=left;verticalAlign=middle;whiteSpace=wrap;fontSize=11;fontColor=#666666;" vertex="1" parent="1"><mxGeometry x="40" y="750" width="700" height="40" as="geometry"/></mxCell><mxCell id="eStoryIssue" value="record the request" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;fontSize=11;labelBackgroundColor=#ffffff;" edge="1" parent="1" source="story" target="issue"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="eIssueTodo" value="create card in TODO column (ChangeReqLab p.1)" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;fontSize=11;labelBackgroundColor=#ffffff;" edge="1" parent="1" source="issue" target="cardTodo"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="eTodoBranch" value="work starts" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;fontSize=11;labelBackgroundColor=#ffffff;" edge="1" parent="1" source="cardTodo" target="cardBranch"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="eBranchCommits" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;" edge="1" parent="1" source="cardBranch" target="cardCommits"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="eCommitsPR" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;" edge="1" parent="1" source="cardCommits" target="cardPR"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="ePRDone" value="merge when green" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;fontSize=11;labelBackgroundColor=#ffffff;" edge="1" parent="1" source="cardPR" target="cardDone"><mxGeometry relative="1" as="geometry"/></mxCell></root></mxGraphModel></diagram></mxfile>
