<mxCell id="t" value="CI Pipeline — GitHub Actions builds every Pull Request (CILab p.1)" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;fontSize=16;fontStyle=1;" vertex="1" parent="1"><mxGeometry x="40" y="10" width="720" height="30" as="geometry"/></mxCell>
<mxCell id="n1" value="Pull Request opened&#10;(trigger: on: pull_request)" style="ellipse;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;" vertex="1" parent="1"><mxGeometry x="40" y="80" width="170" height="60" as="geometry"/></mxCell>
<mxCell id="n2" value="Checkout&#10;(actions/checkout — runner&#10;gets code from the repo)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;" vertex="1" parent="1"><mxGeometry x="260" y="80" width="140" height="60" as="geometry"/></mxCell>
<mxCell id="n3" value="Build&#10;(mvn compile)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;" vertex="1" parent="1"><mxGeometry x="450" y="80" width="140" height="60" as="geometry"/></mxCell>
<mxCell id="n4" value="Unit tests&#10;(mvn test —&#10;self-testing build)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;" vertex="1" parent="1"><mxGeometry x="640" y="80" width="140" height="60" as="geometry"/></mxCell>
<mxCell id="n5" value="Package&#10;(mvn package)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;" vertex="1" parent="1"><mxGeometry x="830" y="80" width="140" height="60" as="geometry"/></mxCell>
<mxCell id="n6" value="Status check:&#10;build green?" style="rhombus;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;" vertex="1" parent="1"><mxGeometry x="820" y="240" width="160" height="90" as="geometry"/></mxCell>
<mxCell id="n7" value="Merge gate on main ✓&#10;branch protection requires the&#10;status check to pass — PR can merge" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;" vertex="1" parent="1"><mxGeometry x="420" y="250" width="240" height="70" as="geometry"/></mxCell>
